        </div>
    </section>

    <!-- Why Us Section -->
    <section id="why-us" class="features-bg">
        <div class="container">
            <h2 class="section-title">Why We Are The Best In Town</h2>
            <div class="features-grid">
                <div class="feature-box">
                    <div class="feature-icon">🔥</div>
