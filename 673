




<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Food Crave | Fast Food, Epic Taste</title>
    <style>
        /* Base Reset & Variables */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        :root {
            --primary: #ff4757;
            --primary-hover: #e84118;
            --secondary: #ffa502;
            --dark: #2f3542;
            --light: #f1f2f6;
            --white: #ffffff;
            --shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        body {
            background-color: #fafafa;
            color: var(--dark);
            line-height: 1.6;
        }

        /* Header & Navigation */
        header {
            background-color: var(--white);
            box-shadow: var(--shadow);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
        }

        .logo {
            font-size: 24px;
            font-weight: 800;
            color: var(--primary);
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .logo span {
            color: var(--secondary);
        }

        .nav-links {
            display: flex;
            list-style: none;
            gap: 25px;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--dark);
            font-weight: 600;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--primary);
        }

        .cta-btn {
            background-color: var(--primary);
            color: var(--white) !important;
            padding: 8px 20px;
            border-radius: 25px;
            transition: background 0.3s !important;
        }

        .cta-btn:hover {
            background-color: var(--primary-hover);
        }

        /* Hero Section */
        .hero {
            background: linear-gradient(rgba(47, 53, 66, 0.85), rgba(47, 53, 66, 0.85)), url('https://images.unsplash.com/photo-1561758033-d89a9ad46330?auto=format&fit=crop&w=1200&q=80') center/cover no-repeat;
            color: var(--white);
            text-align: center;
            padding: 100px 20px;
        }

        .hero h1 {
            font-size: 48px;
            font-weight: 800;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .hero p {
            font-size: 20px;
            margin-bottom: 30px;
            color: var(--light);
        }

        .hero .btn {
            background-color: var(--secondary);
            color: var(--dark);
            padding: 12px 35px;
            text-decoration: none;
            font-weight: 700;
            border-radius: 30px;
            font-size: 18px;
            box-shadow: 0 4px 10px rgba(255, 165, 2, 0.4);
            transition: transform 0.2s, background 0.3s;
            display: inline-block;
        }

        .hero .btn:hover {
            transform: translateY(-2px);
            background-color: #e09202;
        }

        /* Promo Banner */
        .promo-banner {
            background-color: var(--secondary);
            color: var(--dark);
            text-align: center;
            padding: 15px;
            font-weight: 700;
            font-size: 18px;
        }

        /* Main Content Container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 60px 20px;
        }

        .section-title {
            text-align: center;
            font-size: 32px;
            margin-bottom: 40px;
            position: relative;
            padding-bottom: 10px;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 70px;
            height: 4px;
            background-color: var(--primary);
            border-radius: 2px;
        }

        /* Menu Grid */
        .menu-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .menu-card {
            background-color: var(--white);
            border-radius: 15px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.3s;
        }

        .menu-card:hover {
            transform: translateY(-5px);
        }

        .menu-img {
            height: 200px;
            width: 100%;
            object-fit: cover;
            background-color: #ddd;
        }

        .menu-info {
            padding: 20px;
        }

        .menu-title-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .menu-item-name {
            font-size: 20px;
            font-weight: 700;
        }

        .menu-item-price {
            color: var(--primary);
            font-weight: 700;
            font-size: 20px;
        }

        .menu-desc {
            color: #747d8c;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .order-item-btn {
            display: block;
            width: 100%;
            text-align: center;
            background-color: var(--dark);
            color: var(--white);
            padding: 10px;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            transition: background 0.3s;
        }

        .order-item-btn:hover {
            background-color: var(--primary);
        }

        /* Features Section */
        .features-bg {
            background-color: var(--light);
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
            text-align: center;
        }

        .feature-box {
            padding: 20px;
        }

        .feature-icon {
            font-size: 40px;
            margin-bottom: 15px;
        }

        .feature-box h3 {
            margin-bottom: 10px;
            font-size: 20px;
        }

        .feature-box p {
            color: #57606f;
        }

        /* Contact & Info Section */
        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
        }

        .info-col h3 {
            font-size: 22px;
            margin-bottom: 15px;
            color: var(--primary);
        }

        .info-col p {
            margin-bottom: 10px;
            font-size: 16px;
        }

        .social-links a {
            display: inline-block;
            margin-right: 15px;
            color: var(--dark);
            text-decoration: none;
            font-weight: 700;
        }

        .social-links a:hover {
            color: var(--primary);
        }

        /* Footer */
        footer {
            background-color: var(--dark);
            color: var(--white);
            text-align: center;
            padding: 20px;
            font-size: 14px;
        }

        /* Responsive Breakpoints */
        @media (max-width: 768px) {
            .nav-container {
                flex-direction: column;
                gap: 15px;
            }
            .hero h1 {
                font-size: 36px;
            }
            .hero p {
                font-size: 16px;
            }
        }
    </style>
</head>
<body>

